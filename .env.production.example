# ============================================================
# Production environment variables for dianyssa-agent
# Copy this file to .env.production and fill in real values.
# .env.production is ignored by Git — never commit it.
# ============================================================

# --- Deployment ---
# Docker image tag to deploy (e.g. v1.0.0). Do not use "latest" in production.
# Wajib diisi sebelum deploy; biarkan kosong untuk memaksa kesalahan dini.
IMAGE_TAG=

# Public domain where the app will be served (used by Caddy)
APP_DOMAIN=rpp.sekolahmu.id

# Full public URL of the app (used for Telegram magic links and webhooks)
APP_URL=https://rpp.sekolahmu.id

# Port inside the container (leave as 3000 unless you change the image)
PORT=3000

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
INITIAL_ADMIN_TELEGRAM_ID=your_telegram_user_id_here
TELEGRAM_ARCHIVE_CHANNEL_ID=your_telegram_channel_id_here
# Generate a strong random string for webhook verification
TELEGRAM_WEBHOOK_SECRET=generate_a_random_secret_min_32_chars

# --- AI Provider (Gemini) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- IdeTech Website Integration (Telegram content publishing) ---
# Base URL untuk API IdeTech. Harus HTTPS dan reachable dari container ini.
IDETECH_BASE_URL=https://idetech.ferilee.gurumuda.eu.org
# Opsional: admin API key untuk testing/recovery. Setiap aksi publishing
# normalnya menggunakan session token user, bukan key ini. Biarkan kosong
# jika tidak diperlukan.
IDETECH_API_KEY=

# --- Database ---
# Path absolut di dalam container tempat file SQLite disimpan.
# docker-compose.prod.yml mount /app/data ke named volume (sqlite_data).
# Skema tabel dibuat otomatis oleh Nitro plugin saat container boot.
# Untuk migrasi manual (mis. deploy ke server baru sebelum start):
#   DATABASE_URL=/app/data/app.db pnpm exec tsx scripts/run-migration.ts
#   DATABASE_URL=/app/data/app.db pnpm exec tsx scripts/verify-migration.ts
DATABASE_URL=/app/data/app.db

# --- S3 artifact storage ---
# Untuk AWS S3, S3_ENDPOINT boleh dikosongkan.
S3_BUCKET=rpp-artifacts
S3_REGION=ap-southeast-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
